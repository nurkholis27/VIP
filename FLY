-- =====================================================
-- FLY FUNCTIONS
-- =====================================================
local function StartFly()
    if Fly.Active then return end
    Fly.Active = true
    
    -- Create BodyVelocity
    Fly.Velocity = Instance.new("BodyVelocity")
    Fly.Velocity.MaxForce = Vector3.new(100000, 100000, 100000)
    Fly.Velocity.Velocity = Vector3.new(0, 0, 0)
    Fly.Velocity.Parent = HumanoidRootPart
    
    -- Create BodyGyro
    Fly.Gyro = Instance.new("BodyGyro")
    Fly.Gyro.MaxTorque = Vector3.new(100000, 100000, 100000)
    Fly.Gyro.CFrame = HumanoidRootPart.CFrame
    Fly.Gyro.Parent = HumanoidRootPart
    
    Humanoid.PlatformStand = true
    
    -- Noclip
    Fly.Noclip = RunService.Stepped:Connect(function()
        if not Fly.Active then return end
        for _, part in ipairs(Character:GetDescendants()) do
            if part:IsA("BasePart") then
                part.CanCollide = false
            end
        end
    end)
    
    -- Main loop
    Fly.Loop = RunService.Heartbeat:Connect(function()
        if not Fly.Active then return end
        
        local cam = workspace.CurrentCamera
        if not cam then return end
        
        local lookVector = cam.CFrame.LookVector
        local upVector = cam.CFrame.UpVector
        local rightVector = cam.CFrame.RightVector
        
        -- Calculate movement direction
        local moveX = 0
        local moveZ = 0
        
        if Keys.W then moveZ = moveZ + 1 end
        if Keys.S then moveZ = moveZ - 1 end
        if Keys.A then moveX = moveX - 1 end
        if Keys.D then moveX = moveX + 1 end
        
        if TouchControl.Active then
            moveZ = -TouchControl.Y
            moveX = TouchControl.X
        end
        
        local moveDir = Vector3.new(0, 0, 0)
        
        -- Forward/Backward
        if moveZ ~= 0 then
            moveDir = moveDir + lookVector * moveZ
        end
        
        -- Left/Right
        if moveX ~= 0 then
            moveDir = moveDir + rightVector * moveX
        end
        
        -- Up/Down
        if Keys.E then
            moveDir = moveDir + Vector3.new(0, 1, 0)
        end
        if Keys.Q then
            moveDir = moveDir + Vector3.new(0, -1, 0)
        end
        
        -- Normalize and apply speed
        if moveDir.Magnitude > 0 then
            moveDir = moveDir.Unit * Fly.Speed * 100
        end
        
        Fly.Velocity.Velocity = moveDir
        
        -- Face movement direction
        local flatLook = Vector3.new(lookVector.X, 0, lookVector.Z)
        if flatLook.Magnitude > 0 then
            Fly.Gyro.CFrame = CFrame.new(HumanoidRootPart.Position, HumanoidRootPart.Position + flatLook)
        end
    end)
end

local function StopFly()
    Fly.Active = false
    
    if Fly.Loop then
        Fly.Loop:Disconnect()
        Fly.Loop = nil
    end
    
    if Fly.Noclip then
        Fly.Noclip:Disconnect()
        Fly.Noclip = nil
    end
    
    if Fly.Velocity then
        Fly.Velocity:Destroy()
        Fly.Velocity = nil
    end
    
    if Fly.Gyro then
        Fly.Gyro:Destroy()
        Fly.Gyro = nil
    end
    
    -- Restore collision
    for _, part in ipairs(Character:GetDescendants()) do
        if part:IsA("BasePart") then
            part.CanCollide = true
        end
    end
    
    Humanoid.PlatformStand = false
    
    -- Reset keys
    for key in pairs(Keys) do
        Keys[key] = false
    end
    
    TouchControl.Active = false
    TouchControl.X = 0
    TouchControl.Y = 0
end

local function ToggleFly()
    if Fly.Active then
        StopFly()
    else
        StartFly()
    end
end

