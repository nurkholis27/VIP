-- TOUCH CONTROLS (Mobile)
-- =====================================================
if UserInputService.TouchEnabled then
    local TouchFrame = Instance.new("Frame")
    TouchFrame.Size = UDim2.new(0, 120, 0, 120)
    TouchFrame.Position = UDim2.new(0, 30, 1, -150)
    TouchFrame.BackgroundColor3 = Color3.fromRGB(60, 40, 80) -- Changed to dark purple
    TouchFrame.BackgroundTransparency = 0.3
    TouchFrame.BorderSizePixel = 0
    TouchFrame.Parent = FlyGui
    
    local TouchCorner = Instance.new("UICorner")
    TouchCorner.CornerRadius = UDim.new(1, 0)
    TouchCorner.Parent = TouchFrame
    
    local TouchInner = Instance.new("Frame")
    TouchInner.Size = UDim2.new(0, 50, 0, 50)
    TouchInner.Position = UDim2.new(0.5, -25, 0.5, -25)
    TouchInner.BackgroundColor3 = Color3.fromRGB(150, 50, 255) -- Changed to purple
    TouchInner.BackgroundTransparency = 0.2
    TouchInner.BorderSizePixel = 0
    TouchInner.Parent = TouchFrame
    
    local TouchInnerCorner = Instance.new("UICorner")
    TouchInnerCorner.CornerRadius = UDim.new(1, 0)
    TouchInnerCorner.Parent = TouchInner
    
    local TouchConnection = nil
    
    TouchFrame.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.Touch then
            TouchControl.Active = true
            
            TouchConnection = input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then
                    TouchControl.Active = false
                    TouchControl.X = 0
                    TouchControl.Y = 0
                    TouchInner.Position = UDim2.new(0.5, -25, 0.5, -25)
                    if TouchConnection then
                        TouchConnection:Disconnect()
                        TouchConnection = nil
                    end
                else
                    local pos = TouchFrame.AbsolutePosition
                    local size = TouchFrame.AbsoluteSize
                    local touchPos = input.Position
                    
                    local x = (touchPos.X - pos.X) / size.X * 2 - 1
                    local y = (touchPos.Y - pos.Y) / size.Y * 2 - 1
                    
                    local magnitude = math.sqrt(x * x + y * y)
                    if magnitude > 1 then
                        x = x / magnitude
                        y = y / magnitude
                    end
                    
                    if math.abs(x) < 0.15 then x = 0 end
                    if math.abs(y) < 0.15 then y = 0 end
                    
                    TouchControl.X = x
                    TouchControl.Y = y
                    TouchInner.Position = UDim2.new(0.5 + x * 0.4, -25, 0.5 + y * 0.4, -25)
                end
            end)
        end
    end)
end

