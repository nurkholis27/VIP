-- Animation Settings (Fade In, Fade Out, StopOnMove DIHAPUS, Speed TETAP)
local animSettings = {
    Weight = 1,
    Speed = 1,
    AllowInvisible = true,
    TimePosition = 0,
    SpinSpeed = 25 -- Ultra fast default
}

local currentAnimation = nil
local spinConnection = nil
local isSpinning = false

-- Helper function to extract asset ID from URL or direct ID
local function getAssetId(input)
    local num = tonumber(input)
    if num then return num end
    
    local id = string.match(input, "rbxassetid://(%d+)")
    if id then return tonumber(id) end
    
    id = string.match(input, "roblox%.com/catalog/(%d+)")
    if id then return tonumber(id) end
    
    id = string.match(input, "roblox%.com/library/(%d+)")
    if id then return tonumber(id) end
    
    id = string.match(input, "roblox%.com/asset/%?id=(%d+)")
    if id then return tonumber(id) end
    
    return tonumber(input)
end

-- Load and play animation (Fade dihapus, Speed tetap)
local function loadAnimation(assetId)
    if currentAnimation then
        currentAnimation:Stop(0)
    end
    
    local success, objects = pcall(function()
        return game:GetObjects("rbxassetid://" .. tostring(assetId))
    end)
    
    local animId
    if success and objects and #objects > 0 and objects[1]:IsA("Animation") then
        animId = objects[1].AnimationId
    else
        animId = "rbxassetid://" .. tostring(assetId)
    end
    
    local animation = Instance.new("Animation")
    animation.AnimationId = animId
    
    local animTrack = humanoid:LoadAnimation(animation)
    animTrack.Priority = Enum.AnimationPriority.Action4
    
    local weight = animSettings.Weight
    if weight == 0 then weight = 0.001 end
    
    animTrack:Play(0, weight, animSettings.Speed)
    animTrack.TimePosition = math.clamp(animSettings.TimePosition, 0, 1) * animTrack.Length
    
    currentAnimation = animTrack
    return animTrack
end

local function stopAnimation()
    if currentAnimation then
        currentAnimation:Stop(0)
    end
end

-- ============================================================
-- SPIN CHARACTER FUNCTION - ULTRA FAST
-- ============================================================
local function startSpin()
    if isSpinning then return end
    isSpinning = true
    
    spinConnection = RunService.Heartbeat:Connect(function(deltaTime)
        if humanoidRootPart and humanoidRootPart.Parent then
            -- Super fast spin: Speed 1-50, each point adds massive rotation
            local speedMultiplier = animSettings.SpinSpeed * 500 -- 500x multiplier for insane speed
            local spinAmount = speedMultiplier * deltaTime
            humanoidRootPart.CFrame = humanoidRootPart.CFrame * CFrame.Angles(0, math.rad(spinAmount), 0)
        end
    end)
end

local function stopSpin()
    isSpinning = false
    if spinConnection then
        spinConnection:Disconnect()
        spinConnection = nil
    end
end

local function toggleSpin()
    if isSpinning then
        stopSpin()
    else
        startSpin()
    end
end

-- Collision management for "Allow Invisible"
local originalCollisionStates = {}
local currentAllowInvisible = animSettings.AllowInvisible

local function saveOriginalCollision()
    table.clear(originalCollisionStates)
    for _, part in ipairs(character:GetDescendants()) do
        if part:IsA("BasePart") and part ~= humanoidRootPart then
            originalCollisionStates[part] = part.CanCollide
        end
    end
end

local function disableCollisions()
    if not animSettings.AllowInvisible then return end
    for _, part in ipairs(character:GetDescendants()) do
        if part:IsA("BasePart") and part ~= humanoidRootPart then
            part.CanCollide = false
        end
    end
end

local function restoreCollisions()
    for part, canCollide in pairs(originalCollisionStates) do
        if part and part.Parent then
            part.CanCollide = canCollide
        end
    end
    table.clear(originalCollisionStates)
end

local function refreshAllowInvisible()
    local newAllowInvisible = animSettings.AllowInvisible
    if currentAllowInvisible ~= newAllowInvisible then
        if newAllowInvisible then
            saveOriginalCollision()
            disableCollisions()
        else
            restoreCollisions()
        end
        currentAllowInvisible = newAllowInvisible
    elseif newAllowInvisible then
        disableCollisions()
    end
end

