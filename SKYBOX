-- ============================================================
local function createSlider(settingName, minValue, maxValue, currentValue)
    local container = Instance.new("Frame")
    container.Size = UDim2.new(1, 0, 0, 50)
    container.BackgroundTransparency = 1
    container.Parent = settingsScroll
    
    local bg = Instance.new("Frame")
    bg.Size = UDim2.new(1, 0, 1, 0)
    bg.BackgroundColor3 = Color3.fromRGB(18, 16, 32)
    bg.BackgroundTransparency = 0.2
    bg.Parent = container
    local bgCorner = Instance.new("UICorner")
    bgCorner.CornerRadius = UDim.new(0, 6)
    bgCorner.Parent = bg
    
    local label = Instance.new("TextLabel")
    label.Size = UDim2.new(0.5, -5, 0, 18)
    label.Position = UDim2.new(0, 6, 0, 2)
    label.BackgroundTransparency = 1
    label.Text = string.format("%s: %.2f", settingName, currentValue)
    label.TextColor3 = Color3.fromRGB(210, 210, 240)
    label.Font = Enum.Font.Gotham
    label.TextSize = 11
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.Parent = bg
    
    -- Value Input
    local valueInput = Instance.new("TextBox")
    valueInput.Size = UDim2.new(0.35, -5, 0, 18)
    valueInput.Position = UDim2.new(0.65, 0, 0, 2)
    valueInput.BackgroundColor3 = Color3.fromRGB(25, 22, 45)
    valueInput.BackgroundTransparency = 0.3
    valueInput.Text = tostring(currentValue)
    valueInput.TextColor3 = Color3.fromRGB(255, 255, 255)
    valueInput.Font = Enum.Font.Gotham
    valueInput.TextSize = 11
    valueInput.ClearTextOnFocus = false
    valueInput.Parent = bg
    local inputCorner = Instance.new("UICorner")
    inputCorner.CornerRadius = UDim.new(0, 4)
    inputCorner.Parent = valueInput
    
    -- Slider Track
    local sliderBg = Instance.new("Frame")
    sliderBg.Size = UDim2.new(1, -12, 0, 6)
    sliderBg.Position = UDim2.new(0, 6, 0, 26)
    sliderBg.BackgroundColor3 = Color3.fromRGB(35, 30, 55)
    sliderBg.BackgroundTransparency = 0.5
    sliderBg.Parent = bg
    local sliderBgCorner = Instance.new("UICorner")
    sliderBgCorner.CornerRadius = UDim.new(0, 3)
    sliderBgCorner.Parent = sliderBg
    
    -- Slider Fill
    local sliderFill = Instance.new("Frame")
    sliderFill.Size = UDim2.new(0, 0, 1, 0)
    sliderFill.BackgroundColor3 = Color3.fromRGB(255, 70, 200)
    sliderFill.Parent = sliderBg
    local fillCorner = Instance.new("UICorner")
    fillCorner.CornerRadius = UDim.new(0, 3)
    fillCorner.Parent = sliderFill
    
    -- Slider Knob
    local sliderKnob = Instance.new("Frame")
    sliderKnob.Size = UDim2.new(0, 14, 0, 14)
    sliderKnob.AnchorPoint = Vector2.new(0.5, 0.5)
    sliderKnob.Position = UDim2.new(0, 0, 0.5, 0)
    sliderKnob.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
    sliderKnob.Parent = sliderBg
    local knobCorner = Instance.new("UICorner")
    knobCorner.CornerRadius = UDim.new(1, 0)
    knobCorner.Parent = sliderKnob
    
    local function updateSliderUI(value)
        local t = math.clamp(value, minValue, maxValue)
        local percent = (t - minValue) / (maxValue - minValue)
        
        TweenService:Create(sliderFill, TweenInfo.new(0.12, Enum.EasingStyle.Quad), {
            Size = UDim2.new(percent, 0, 1, 0)
        }):Play()
        
        TweenService:Create(sliderKnob, TweenInfo.new(0.12, Enum.EasingStyle.Quad), {
            Position = UDim2.new(percent, 0, 0.5, 0)
        }):Play()
    end
    
    local function setValue(value)
        local clamped = math.floor((minValue + (maxValue - minValue) * math.clamp((value - minValue) / (maxValue - minValue), 0, 1)) * 100) / 100
        animSettings[settingName] = clamped
        label.Text = string.format("%s: %.2f", settingName, clamped)
        valueInput.Text = tostring(clamped)
        updateSliderUI(clamped)
        
        if currentAnimation and currentAnimation.IsPlaying then
            if settingName == "Speed" then
                currentAnimation:AdjustSpeed(animSettings.Speed)
            elseif settingName == "Weight" then
                local weight = animSettings.Weight
                if weight == 0 then weight = 0.001 end
                currentAnimation:AdjustWeight(weight)
            elseif settingName == "Time Position" then
                if currentAnimation.Length > 0 then
                    currentAnimation.TimePosition = math.clamp(clamped, 0, 1) * currentAnimation.Length
                end
            end
        end
    end
    
    local dragging = false
    
    local function onSliderInput(input)
        local percent = math.clamp((input.Position.X - sliderBg.AbsolutePosition.X) / sliderBg.AbsoluteSize.X, 0, 1)
        local newValue = minValue + (maxValue - minValue) * percent
        setValue(newValue)
    end
    
    sliderBg.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            onSliderInput(input)
        end
    end)
    
    sliderKnob.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            onSliderInput(input)
        end
    end)
    
    UserInputService.InputChanged:Connect(function(input)
        if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
            onSliderInput(input)
        end
    end)
    
    UserInputService.InputEnded:Connect(function()
        dragging = false
    end)
    
    valueInput.FocusLost:Connect(function(enterPressed)
        if enterPressed then
            local num = tonumber(valueInput.Text)
            if num then
                setValue(num)
            else
                valueInput.Text = tostring(animSettings[settingName])
            end
        end
    end)
    
    setValue(currentValue)
end

