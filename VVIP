local function GenerateKey()
    local chars = "ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789"
    local key = ""
    for i = 1, math.random(25, 40) do
        key = key .. string.sub(chars, math.random(1, #chars), math.random(1, #chars))
    end
    return key
end

local function EncryptString(str)
    local key = GenerateKey()
    local encrypted = ""
    for i = 1, #str do
        local byte = string.byte(str, i)
        local keyByte = string.byte(key, (i % #key) + 1)
        encrypted = encrypted .. string.char(bit32.bxor(byte, keyByte))
    end
    return encrypted, key
end

