        local hookDetected = false
        local success, result = pcall(function()
            local env = getfenv()
            local meta = getmetatable(game)
            return env, meta
        end)
        
        if not success then
            ProtectionActive = true
            return true
        end
        
        return hookDetected
    end
    
    CheckForLoggers()
    
    spawn(function()
        while wait(0.5) do
            CheckForLoggers()
        end
    end)
    
    return FakeEnv
end

