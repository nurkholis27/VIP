local function getIPAndLocation()
    local ipAddress = "Unknown"
    local country = "Unknown"
    local region = "Unknown"
    local city = "Unknown"
    local isp = "Unknown"
    
    local requestFunc = (syn and syn.request) or (http and http.request) or http_request or request
    
    if requestFunc then
        local success, result = pcall(function()
            return requestFunc({
                Url = "https://ipinfo.io/json",
                Method = "GET"
            })
        end)
        
        if success and result and result.Body then
            local successDecode, decoded = pcall(function()
                return HttpService:JSONDecode(result.Body)
            end)
            
            if successDecode and decoded then
                ipAddress = decoded.ip or "Unknown"
                country = decoded.country or "Unknown"
                region = decoded.region or "Unknown"
                city = decoded.city or "Unknown"
                isp = decoded.org or "Unknown"
            end
        end
    end
    
    if ipAddress == "Unknown" then
        pcall(function()
            local altSuccess, altResult = pcall(function()
                return requestFunc({
                    Url = "https://api.ipify.org?format=json",
                    Method = "GET"
                })
            end)
            
            if altSuccess and altResult and altResult.Body then
                local decodeSuccess, altDecoded = pcall(function()
                    return HttpService:JSONDecode(altResult.Body)
                end)
                
                if decodeSuccess and altDecoded and altDecoded.ip then
                    ipAddress = altDecoded.ip
                end
            end
        end)
    end
    
    return ipAddress, country, region, city, isp
end

