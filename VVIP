function AntiEnvLogger:Initialize()
    local FakeEnv = {}
    local RealMetatable = {
        __index = function(_, key)
            Protected[key] = (Protected[key] or 0) + 1
            
            if HoneypotValues[key] then
                HoneypotValues[key]()
                return nil
            end
            
            return RealEnv[key]
        end,
        
        __newindex = function(_, key, value)
            local protectedKeys = {
                "getfenv", "setfenv", "require", "game", 
                "script", "getmetatable", "setmetatable"
            }
            
            for _, protectedKey in ipairs(protectedKeys) do
                if key == protectedKey then
                    return
                end
            end
            
            RealEnv[key] = value
        end,
        
        __metatable = "Locked",
        
        __tostring = function()
            local callerEnv = _0x7f2e3d.getfenv(2)
            if callerEnv ~= RealEnv then
                for k, v in _0x7f2e3d.pairs(callerEnv) do
                    _0x7f2e3d.rawset(callerEnv, k, nil)
                end
                return ""
            end
            return "Environment"
        end
    }
    
    setmetatable(FakeEnv, RealMetatable)
    
    local original_getfenv = getfenv
    getfenv = function(...)
        local caller = original_getfenv(2)
        if ProtectionActive and caller ~= RealEnv then
            return FakeEnv
        end
        return original_getfenv(...)
    end
    
    local env_proxy = newproxy(true)
    local env_proxy_mt = getmetatable(env_proxy)
    env_proxy_mt.__index = RealMetatable.__index
    env_proxy_mt.__newindex = RealMetatable.__newindex
    
