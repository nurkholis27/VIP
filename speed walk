-- UI REFERENCES
-- ================================================
local UI = {
    SpeedDisplay = nil,
    SpeedInput = nil,
    StatusTxt = nil,
    ToggleBtn = nil,
    MinusBtn = nil,
    PlusBtn = nil
}

local function UpdateUI()
    if UI.SpeedDisplay then
        UI.SpeedDisplay.Text = SpeedWalk.Speed
    end
    
    if UI.SpeedInput then
        UI.SpeedInput.Text = SpeedWalk.Speed
    end
    
    if UI.StatusTxt then
        local status = SpeedWalk.Enabled and "ON" or "OFF"
        UI.StatusTxt.Text = "STATUS: " .. status .. "  |  SPEED: " .. SpeedWalk.Speed
        UI.StatusTxt.TextColor3 = SpeedWalk.Enabled and COLORS.Green or COLORS.TextDim
    end
    
    if UI.ToggleBtn then
        if SpeedWalk.Enabled then
            UI.ToggleBtn.Text = "🔒 DISABLE"
            UI.ToggleBtn.BackgroundColor3 = COLORS.Green
        else
            UI.ToggleBtn.Text = "🔓 ENABLE"
            UI.ToggleBtn.BackgroundColor3 = COLORS.Blue
        end
    end
end

