-- ================================================
-- UI HELPERS
-- ================================================
local function MakeCorner(obj, radius)
    local c = Instance.new("UICorner", obj)
    c.CornerRadius = UDim.new(0, radius or 8)
    return c
end

local function MakeStroke(obj, color, thickness)
    local s = Instance.new("UIStroke", obj)
    s.Color = color or COLORS.Blue
    s.Thickness = thickness or 1.5
    s.Transparency = 0.4
    s.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
    return s
end

local function MakeDraggable(frame)
    local dragging, dragStart, startPos
    frame.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            dragStart = input.Position
            startPos = frame.Position
            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then dragging = false end
            end)
        end
    end)
    frame.InputChanged:Connect(function(input)
        if (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) and dragging then
            local delta = input.Position - dragStart
            frame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
        end
    end)
end

-- ================================================
-- SPEED WALK ENGINE
-- ================================================
local function EnableSpeedWalk()
    if SpeedWalk.Enabled then return end
    
    local character = LocalPlayer.Character
    if not character then return end
    
    local humanoid = character:FindFirstChildOfClass("Humanoid")
    if not humanoid then return end
    
    SpeedWalk.OriginalSpeed = humanoid.WalkSpeed
    humanoid.WalkSpeed = SpeedWalk.Speed
    
    SpeedWalk.Enabled = true
    
    UpdateUI()
    print("[SPEED] Enabled | Speed: " .. SpeedWalk.Speed)
end

local function DisableSpeedWalk()
    if not SpeedWalk.Enabled then return end
    
    SpeedWalk.Enabled = false
    
    local character = LocalPlayer.Character
    if character then
        local humanoid = character:FindFirstChildOfClass("Humanoid")
        if humanoid then
            humanoid.WalkSpeed = SpeedWalk.OriginalSpeed
        end
    end
    
    UpdateUI()
    print("[SPEED] Disabled")
end

local function ToggleSpeedWalk()
    if SpeedWalk.Enabled then
        DisableSpeedWalk()
    else
        EnableSpeedWalk()
    end
end

local function ApplySpeed()
    if SpeedWalk.Enabled then
        local character = LocalPlayer.Character
        if character then
            local humanoid = character:FindFirstChildOfClass("Humanoid")
            if humanoid then
                humanoid.WalkSpeed = SpeedWalk.Speed
            end
        end
    end
end

local function SetSpeed(value)
    local newSpeed = math.floor(math.clamp(value, SpeedWalk.MinSpeed, SpeedWalk.MaxSpeed))
    SpeedWalk.Speed = newSpeed
    UpdateUI()
    ApplySpeed()
    print("[SPEED] Set to: " .. SpeedWalk.Speed)
end

local function IncreaseSpeed()
    SetSpeed(SpeedWalk.Speed + SpeedWalk.Step)
end

local function DecreaseSpeed()
    SetSpeed(SpeedWalk.Speed - SpeedWalk.Step)
end

-- ================================================
-- RESPAWN HANDLER
-- ================================================
LocalPlayer.CharacterAdded:Connect(function(newChar)
    if SpeedWalk.Enabled then
        task.wait(0.5)
        local humanoid = newChar:FindFirstChildOfClass("Humanoid")
        if humanoid then
            humanoid.WalkSpeed = SpeedWalk.Speed
        end
        print("[SPEED] Reapplied on respawn")
    end
end)

